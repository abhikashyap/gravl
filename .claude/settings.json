{
  "hooks": {
    "SubagentStart": [
      { "matcher": ".*", "hooks": [ { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/agent-tracker.sh", "timeout": 5 } ] }
    ],
    "SubagentStop": [
      { "matcher": ".*", "hooks": [ { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/agent-tracker.sh", "timeout": 5 } ] }
    ],
    "PreToolUse": [
      { "matcher": "Agent", "hooks": [ { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/agent-tracker.sh", "timeout": 5 } ] }
    ],
    "PreCompact": [
      { "hooks": [ { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-compact.sh", "timeout": 10, "statusMessage": "Saving state before compaction..." } ] }
    ],
    "Stop": [
      { "hooks": [
        { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-end.sh", "timeout": 15, "statusMessage": "Saving session..." },
        { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/agent-tracker.sh", "timeout": 5 }
      ] }
    ],
    "SessionStart": [
      { "hooks": [
        { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start.sh", "timeout": 10, "statusMessage": "Loading previous session context..." },
        { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/cleanup-screenshots.sh", "timeout": 5, "statusMessage": "Cleaning up screenshots..." }
      ] }
    ],
    "SessionEnd": [
      { "hooks": [
        { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-end.sh", "timeout": 15 },
        { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/agent-tracker.sh", "timeout": 5 }
      ] }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/statusline-command.sh"
  }
}
